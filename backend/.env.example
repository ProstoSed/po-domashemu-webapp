# Токен нового бота (получить у @BotFather)
BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Telegram ID владельца (получатель заказов)
MAIN_CHAT_ID=123456789

# URL задеплоенного frontend (после деплоя на Vercel)
WEBAPP_URL=https://your-app.vercel.app

# Дополнительные администраторы (через запятую, без пробелов)
# Владелец уже добавлен автоматически через MAIN_CHAT_ID.
# Пример: ADMIN_IDS=5541118089,987654321
ADMIN_IDS=

# Путь к prices.json (относительно run.py)
PRICES_FILE=../../data/prices.json
